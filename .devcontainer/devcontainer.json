{
  "name": "POC AURA - Full Stack Dev",
  "dockerComposeFile": ["../docker-compose.dev.yml"],
  "service": "workspace",
  "workspaceFolder": "/workspace",
  "runServices": ["sqlserver", "cloudbeaver", "workspace"],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csharp",
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.vscode-dotnet-runtime",
        "ms-dotnettools.blazorwasm-companion",
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "PKief.material-icon-theme",
        "christian-kohler.path-intellisense"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[csharp]": {
          "editor.defaultFormatter": "ms-dotnettools.csharp"
        },
        "editor.tabSize": 2,
        "terminal.integrated.defaultProfile.linux": "bash",
        "dotnet.defaultSolution": "/workspace/POC.sln"
      }
    }
  },

  "forwardPorts": [5000, 5001, 4200, 8978, 1433],
  "portsAttributes": {
    "5000": { "label": "Backend API / Swagger", "onAutoForward": "notify" },
    "5001": { "label": "Blazor SmartHub", "onAutoForward": "notify" },
    "4200": { "label": "Angular Dev Server", "onAutoForward": "openBrowser" },
    "8978": { "label": "CloudBeaver DB Manager", "onAutoForward": "notify" },
    "1433": { "label": "SQL Server", "onAutoForward": "silent" }
  },

  "postCreateCommand": "cd /workspace/backend && dotnet restore POC.AURA.Api/POC.AURA.Api.csproj && cd /workspace/blazor && dotnet restore POC.AURA.SmartHub/POC.AURA.SmartHub.csproj && cd /workspace/frontend && npm install",

  "remoteUser": "root"
}
