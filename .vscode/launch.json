{
  "version": "0.2.0",
  "configurations": [

    // ─── Backend ─────────────────────────────────────────────────────────
    {
      "name": "🔵 Backend: Launch & Debug",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: backend",
      "program": "/workspace/backend/POC.AURA.Api/bin/Debug/net8.0/POC.AURA.Api.dll",
      "args": [],
      "cwd": "/workspace/backend/POC.AURA.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://0.0.0.0:5000",
        "ConnectionStrings__DefaultConnection": "Server=sqlserver,1433;Database=PocAuraDb;User Id=sa;Password=Aura@Poc2024!;TrustServerCertificate=True;"
      },
      "justMyCode": true
    },
    {
      "name": "🔵 Backend: Attach (dotnet watch)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": true
    },

    // ─── Blazor SmartHub ──────────────────────────────────────────────────
    {
      "name": "🟣 Blazor: Launch & Debug",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: blazor",
      "program": "/workspace/blazor/POC.AURA.SmartHub/bin/Debug/net8.0/POC.AURA.SmartHub.dll",
      "args": [],
      "cwd": "/workspace/blazor/POC.AURA.SmartHub",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://0.0.0.0:5001",
        "Backend__Url": "http://localhost:5000"
      },
      "justMyCode": true
    },
    {
      "name": "🟣 Blazor: Attach (dotnet watch)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": true
    },

    // ─── Frontend ─────────────────────────────────────────────────────────
    {
      "name": "🟠 Frontend: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "ng:///*": "${webRoot}/*"
      }
    },
    {
      "name": "🟠 Frontend: Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "ng:///*": "${webRoot}/*"
      }
    }
  ],

  "compounds": [
    {
      "name": "🚀 Full Stack Debug (BE + FE)",
      "configurations": ["🔵 Backend: Launch & Debug", "🟠 Frontend: Chrome"],
      "stopAll": true
    },
    {
      "name": "🚀 Full Stack Debug (BE + Blazor + FE)",
      "configurations": ["🔵 Backend: Launch & Debug", "🟣 Blazor: Launch & Debug", "🟠 Frontend: Chrome"],
      "stopAll": true
    }
  ]
}
