{
  "version": "0.2.0",
  "configurations": [
    // ─── Backend: Launch với debugger (F5) ────────────────────────────────
    // Dùng khi ở trong Dev Container — build rồi launch thẳng, không cần pipe
    {
      "name": "🔵 Backend: Launch & Debug",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build: backend",
      "program": "/workspace/backend/POC.AURA.Api/bin/Debug/net8.0/POC.AURA.Api.dll",
      "args": [],
      "cwd": "/workspace/backend/POC.AURA.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://0.0.0.0:5000",
        "ConnectionStrings__DefaultConnection": "Server=sqlserver,1433;Database=PocAuraDb;User Id=sa;Password=Aura@Poc2024!;TrustServerCertificate=True;"
      },
      "justMyCode": true
    },

    // ─── Backend: Attach vào process đang chạy (dotnet watch) ────────────
    // Dùng khi đã có `dotnet watch run` đang chạy trong terminal
    {
      "name": "🔵 Backend: Attach (process)",
      "type": "coreclr",
      "request": "attach",
      "processId": "${command:pickProcess}",
      "justMyCode": true
    },

    // ─── Frontend: Chrome debugger ────────────────────────────────────────
    {
      "name": "🟠 Frontend: Chrome (localhost:4200)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "ng:///*": "${webRoot}/*"
      }
    },

    // ─── Frontend: Edge debugger ──────────────────────────────────────────
    {
      "name": "🟠 Frontend: Edge (localhost:4200)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}/frontend/src",
      "sourceMapPathOverrides": {
        "webpack:///./src/*": "${webRoot}/*",
        "ng:///*": "${webRoot}/*"
      }
    }
  ],

  "compounds": [
    {
      "name": "🚀 Full Stack Debug",
      "configurations": ["🔵 Backend: Launch & Debug", "🟠 Frontend: Chrome (localhost:4200)"],
      "stopAll": true
    }
  ]
}
