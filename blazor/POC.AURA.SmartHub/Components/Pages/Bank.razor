@page "/bank"
@rendermode InteractiveServer
@inject BankHubService BankSvc

<div class="page">

  <div class="page-header">
    <h1>Bank Processor — Transaction Engine</h1>
  </div>

  <!-- ── Tenant Status ──────────────────────────────────────────────────── -->
  <div class="card">
    <div class="card-title">Tenant Connections</div>
    <div class="tenant-grid">
      @foreach (var (tenant, status) in BankSvc.TenantStatuses)
      {
        <div class="tenant-item">
          <span class="badge @StatusClass(status)">@status.ToUpper()</span>
          <span class="tenant-name">@tenant — group: bank-@tenant</span>
        </div>
      }
      @if (BankSvc.TenantStatuses.Count == 0)
      {
        <div class="empty">Connecting...</div>
      }
    </div>
  </div>

  <!-- ── Currently Processing ───────────────────────────────────────────── -->
  <div class="card">
    <div class="card-title">
      Currently Processing
      @if (BankSvc.ProcessingQueue.Count > 0)
      {
        <span class="count-badge processing-pulse">@BankSvc.ProcessingQueue.Count</span>
      }
    </div>

    @if (BankSvc.ProcessingQueue.Count == 0)
    {
      <div class="empty">Waiting for transactions...</div>
    }
    else
    {
      @foreach (var job in BankSvc.ProcessingQueue.ToList())
      {
        <div class="processing-item">
          <div class="pi-spinner"></div>
          <div class="pi-info">
            <div class="pi-id">TXN-@job.TransactionId</div>
            <div class="pi-desc">@job.Description</div>
            <div class="pi-meta">@job.Amount.ToString("N0") @job.Currency &nbsp;·&nbsp; @job.SubmittedAt.ToLocalTime().ToString("HH:mm:ss")</div>
          </div>
          <div class="pi-status">Verifying...</div>
        </div>
      }
    }
  </div>

  <!-- ── Completed ──────────────────────────────────────────────────────── -->
  @if (BankSvc.CompletedJobs.Count > 0)
  {
    <div class="card">
      <div class="card-title">Processed Transactions (last @Math.Min(BankSvc.CompletedJobs.Count, 10))</div>
      <div class="completed-list">
        @foreach (var (result, time) in BankSvc.CompletedJobs.TakeLast(10).Reverse())
        {
          <div class="completed-item @(result.Success ? "completed-ok" : "completed-fail")">
            <span>@(result.Success ? "✓" : "✗")</span>
            <span class="job-id">TXN-@result.TransactionId</span>
            <span>@result.Message</span>
            <span class="completed-time">@time.ToString("HH:mm:ss")</span>
          </div>
        }
      </div>
    </div>
  }

  <!-- ── Activity Log ───────────────────────────────────────────────────── -->
  <div class="card">
    <div class="card-title">Activity Log</div>
    <div class="log-box">
      @foreach (var (level, msg, time) in BankSvc.Logs.TakeLast(30).Reverse())
      {
        <div class="log-entry log-@level">
          <span class="log-time">@time.ToString("HH:mm:ss")</span>
          <span>@msg</span>
        </div>
      }
      @if (BankSvc.Logs.Count == 0)
      {
        <div class="log-empty">No activity yet.</div>
      }
    </div>
  </div>

</div>

@code {
    protected override void OnInitialized()
    {
        BankSvc.StateChanged += OnStateChanged;
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    private static string StatusClass(string status) => status switch
    {
        "connected"    => "badge-green",
        "connecting"   => "badge-yellow",
        "reconnecting" => "badge-yellow",
        _              => "badge-gray"
    };

    public void Dispose()
    {
        BankSvc.StateChanged -= OnStateChanged;
    }
}
