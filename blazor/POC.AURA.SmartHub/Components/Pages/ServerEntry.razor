@page "/server-entry"
@rendermode InteractiveServer
@inject ServerConnectionService ConnSvc
@inject NavigationManager Nav

<div class="page">
  <div class="page-header">
    <h1>Add Server Connection</h1>
    <p class="page-sub">Enter the Aura server URL and tenant ID to connect.</p>
  </div>

  <div class="card form-card">
    <div class="form-group">
      <label>Server Name</label>
      <input class="input" @bind="_name" placeholder="e.g. Production — TenantA" />
    </div>

    <div class="form-group">
      <label>Aura Server URL</label>
      <input class="input" @bind="_serverUrl" placeholder="http://localhost:5000" />
      <div class="input-hint">Base URL of the Aura API (no trailing slash needed)</div>
    </div>

    <div class="form-group">
      <label>Tenant ID</label>
      <input class="input" @bind="_tenantId" placeholder="TenantA" />
      <div class="input-hint">Identifies the tenant on the Aura server</div>
    </div>

    @if (_error is not null)
    {
      <div class="alert alert-error">@_error</div>
    }

    <div class="form-actions">
      <a class="btn btn-outline" href="/">Cancel</a>
      <button class="btn btn-primary" @onclick="SubmitAsync" disabled="@_busy">
        @if (_busy) { <span class="spinner"></span> } Connect & Authenticate
      </button>
    </div>

    <div class="auth-note">
      <strong>What happens next:</strong>
      <ol>
        <li>SmartHub calls <code>/api/auth/token</code> on the Aura server</li>
        <li>Access token is stored in local SQLite database</li>
        <li>Print and bank hub connections are established automatically</li>
        <li>Token is refreshed proactively before expiry</li>
      </ol>
    </div>
  </div>
</div>

@code {
  private string _name      = "";
  private string _serverUrl = "";
  private string _tenantId  = "";
  private string? _error;
  private bool _busy;

  private async Task SubmitAsync()
  {
    _error = null;

    if (string.IsNullOrWhiteSpace(_name))     { _error = "Server name is required."; return; }
    if (string.IsNullOrWhiteSpace(_serverUrl)) { _error = "Server URL is required."; return; }
    if (string.IsNullOrWhiteSpace(_tenantId))  { _error = "Tenant ID is required."; return; }

    _busy = true;
    var (ok, error) = await ConnSvc.AddServerAsync(_name.Trim(), _serverUrl.Trim(), _tenantId.Trim());
    _busy = false;

    if (ok) Nav.NavigateTo("/");
    else    _error = error ?? "Unknown error";
  }
}
