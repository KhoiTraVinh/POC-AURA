@page "/print"
@rendermode InteractiveServer
@inject HubConnectionWorker Worker
@implements IDisposable

<div class="page">

  <div class="page-header">
    <h1>Print Hub — Job Queue</h1>
  </div>

  <!-- ── Connection Status ─────────────────────────────────────────────── -->
  <div class="card">
    <div class="card-title">Server Connections</div>
    <div class="tenant-grid">
      @foreach (var (id, (name, status, tenant)) in Worker.ConnectionStatuses)
      {
        <div class="tenant-item">
          <span class="badge @StatusClass(status)">@status.ToUpper()</span>
          <span class="tenant-name">@name / @tenant</span>
        </div>
      }
      @if (Worker.ConnectionStatuses.Count == 0)
      {
        <div class="empty">No connections — <a href="/">add a server</a></div>
      }
    </div>
  </div>

  <!-- ── Pending Jobs ───────────────────────────────────────────────────── -->
  <div class="card">
    <div class="card-title">
      Pending Print Jobs
      @if (Worker.PendingPrintJobs.Count > 0)
      {
        <span class="count-badge">@Worker.PendingPrintJobs.Count</span>
      }
    </div>
    @if (Worker.PendingPrintJobs.Count == 0)
    {
      <div class="empty">Waiting for print jobs…</div>
    }
    else
    {
      <div class="job-list">
        @foreach (var job in Worker.PendingPrintJobs.ToList())
        {
          <div class="job-item">
            <div class="job-meta">
              <span class="job-id">#@job.Id</span>
              <span class="job-name">@job.DocumentName</span>
              <span class="job-copies">×@job.Copies</span>
              <span class="job-tenant">[@job.TenantId]</span>
              <span class="job-time">@job.CreatedAt.ToLocalTime().ToString("HH:mm:ss")</span>
            </div>
            <div class="job-content">@job.Content</div>
          </div>
        }
      </div>
    }
  </div>

  <!-- ── Completed ─────────────────────────────────────────────────────── -->
  @if (Worker.CompletedPrintJobs.Count > 0)
  {
    <div class="card">
      <div class="card-title">Completed (last @Math.Min(Worker.CompletedPrintJobs.Count, 10))</div>
      <div class="completed-list">
        @foreach (var (result, time) in Worker.CompletedPrintJobs.TakeLast(10).Reverse())
        {
          <div class="completed-item @(result.Success ? "completed-ok" : "completed-fail")">
            <span>@(result.Success ? "✓" : "✗")</span>
            <span class="job-id">#@result.JobId</span>
            <span class="job-tenant">[@result.TenantId]</span>
            <span>@result.Message</span>
            <span class="completed-time">@time.ToString("HH:mm:ss")</span>
          </div>
        }
      </div>
    </div>
  }

  <!-- ── Log ───────────────────────────────────────────────────────────── -->
  <div class="card">
    <div class="card-title">Activity Log</div>
    <div class="log-box">
      @foreach (var (level, msg, time) in Worker.Logs.TakeLast(30).Reverse())
      {
        <div class="log-entry log-@level">
          <span class="log-time">@time.ToString("HH:mm:ss")</span>
          <span>@msg</span>
        </div>
      }
      @if (!Worker.Logs.Any()) { <div class="log-empty">No activity yet.</div> }
    </div>
  </div>

</div>

@code {
  protected override void OnInitialized() => Worker.StateChanged += Refresh;
  private void Refresh() => InvokeAsync(StateHasChanged);

  private static string StatusClass(string s) => s switch
  {
    "connected"    => "badge-green",
    "connecting"   => "badge-yellow",
    "reconnecting" => "badge-yellow",
    _ => "badge-gray"
  };

  public void Dispose() => Worker.StateChanged -= Refresh;
}
